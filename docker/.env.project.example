# 設備台帳管理システム固有の追加環境変数
#
# Supabase公式の .env（generate-keys.sh / add-new-auth-keys.sh 実行後のもの）に、
# 下記の値を追記・変更して使う。追記後は `sh run.sh recreate` 等で反映させること。
#
# .env はシークレットを含むため、db-repo（Git管理対象）には絶対にコミットしないこと。
# このファイル自体（.env.project.example）はプレースホルダのみなのでコミット可。

# ==== 既存の公式.envの中で、値を変更する項目 ====
# （キーはすでに.env内に存在する。プレースホルダから実際の値に書き換える）
#
# SUPABASE_PUBLIC_URL=https://<公開ドメイン>
# API_EXTERNAL_URL=https://<公開ドメイン>/auth/v1
# SITE_URL=https://<公開ドメイン>
# PROXY_DOMAIN=<公開ドメイン>                    # スキームなし。Caddyfileのサイトブロックで使用
# DASHBOARD_USERNAME=<運用担当者用の任意のユーザー名>
# DASHBOARD_PASSWORD=<安全なパスワードに変更。初期値のまま運用しないこと>
# FUNCTIONS_VERIFY_JWT=false                     # 既定値のまま。X-API-Key認証のみで運用するため変更不要

# ==== 本システム固有の追加項目（.envの末尾に新規追記） ====
#
# 注意: .envファイル自体はシェルではないため、値の中で ${変数名} を書いても展開されない
# （docker compose が.envを読むときに他の.env内の変数を再展開する機能はない）。
# 下記の DB_REPO_DIR・WEBAPP_SOURCE_DIR・COMPOSE_FILE は、実際の絶対パスに
# 置き換えた文字列をそのまま書き込むこと。README「2. 鍵・URLを設定」に、
# シェルの変数展開を使って安全に追記するコマンド例を用意している。

# 外部インターフェースAPI（Edge Functions）のAPIキー認証。
# db-repo/supabase/functions/*/index.ts が Deno.env.get("EXTERNAL_API_KEY") で参照する。
# docker-compose.webapp.yml のfunctionsサービスへの環境変数追加で反映される。
# 現行Supabase Cloudで発行済みの値をそのまま引き継ぐか、新規に発行する。
EXTERNAL_API_KEY=

# db-repo リポジトリの絶対パス（サーバー上でgit cloneした場所）。例: /home/db-repo
# webapp配信コンテナ・マイグレーション適用スクリプト・Edge Functions配置スクリプトが
# このパスを基準に db-repo 配下のファイルを参照する。
DB_REPO_DIR=/absolute/path/to/db-repo

# webapp配信コンテナが読みに行く静的ファイルの場所。
# 通常は「DB_REPO_DIRの値 + /webapp」（例: /home/db-repo/webapp）。
WEBAPP_SOURCE_DIR=/absolute/path/to/db-repo/webapp

# ==== COMPOSE_FILE への追記 ====
# .envのCOMPOSE_FILE（既定値: docker-compose.yml）に、以下を ":" 区切りで追記する
# （":"区切りはこのファイル自体がLinux上のCOMPOSE_FILE仕様に従うため。値は絶対パスで書く）。
# 例（DB_REPO_DIRが /home/db-repo の場合）:
#   COMPOSE_FILE=docker-compose.yml:docker-compose.caddy.yml:/home/db-repo/docker/docker-compose.webapp.yml
# これにより、`sh run.sh start` 等の公式コマンドがCaddy・webapp・functions環境変数の
# 追加分もまとめて起動・再作成するようになる。
