# 設備台帳管理システム Caddy設定
#
# セットアップ時に、セルフホストスタックの volumes/proxy/caddy/Caddyfile を
# このファイルの内容で置き換える（README・移行計画書5.7節参照）。
# ベースは公式の docker-compose.caddy.yml が生成する既定のCaddyfileで、
# 差分は次の2点のみ:
#   1. Supabase Studio（管理画面）を既定の "/"（Basic認証つき）から "/studio/*" に退避
#   2. それ以外（"/" など）を、本システムのWebアプリ（webappコンテナ）に振り分け
#
# PROXY_DOMAIN・PROXY_AUTH_USERNAME・PROXY_AUTH_PASSWORD は、公式の
# docker-compose.caddy.yml がcaddyコンテナの環境変数として渡す（.envのPROXY_DOMAIN・
# DASHBOARD_USERNAME・DASHBOARD_PASSWORDから。README参照）。

{$PROXY_DOMAIN} {
	@supabase_api path /auth/v1/* /rest/v1/* /graphql/v1 /realtime/v1/* /storage/v1/* /functions/v1/* /mcp /sso/*

	handle @supabase_api {
		reverse_proxy kong:8000
	}

	handle /studio/* {
		basic_auth {
			# PROXY_AUTH_PASSWORDは起動時にbcryptハッシュへ上書きされる
			{$PROXY_AUTH_USERNAME} {$PROXY_AUTH_PASSWORD}
		}
		uri strip_prefix /studio
		reverse_proxy studio:3000
	}

	handle {
		reverse_proxy webapp:80
	}

	header -server
}
